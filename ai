## apps/api/src/modules/webhook.controller.ts (webhook для событий от бота)
```ts
import { Controller, Post, Headers, Body } from '@nestjs/common';
import { prisma } from '@danika/db/src/index.js';
import fetch from 'node-fetch';

@Controller('telegram')
export class WebhookController {
  @Post('webhook')
  async webhook(@Headers('x-telegram-bot-api-secret-token') secret: string, @Body() update: any) {
    if (secret !== process.env.TELEGRAM_WEBHOOK_SECRET) return { ok: true };

    const message = update.message || update.channel_post;
    if (!message) return { ok: true };
    const chat = await prisma.chat.findFirst({ where: { chatId: String(message.chat.id) }, include: { settings: true, bot: { include: { owner: { include: { subscriptions: true } } } } } });
    if (!chat?.settings?.enabled) return { ok: true };

    // проверка подписки владельца
    const owner = chat.bot.owner;
    const active = owner.subscriptions.some(s => s.status === 'active' && s.currentPeriodEnd > new Date());
    if (!active) return { ok: true };

    const text: string = message.text ?? '';

    // простой вызов LLM (заглушка, лучше вынести в воркер)
    const sys = `Твоя задача: ${chat.settings.prompt || 'Отвечай кратко и полезно.'}`;
    const reply = await simpleOpenAI(sys, text, chat.settings.maxTokens ?? 256, chat.settings.temperature ?? 0.7);

    await sendTelegramMessage(chat.bot.tokenEnc, message.chat.id, reply);
    await prisma.usageLog.create({ data: { chatId: chat.id, tokens: reply.length } });
    return { ok: true };
  }
}

async function simpleOpenAI(system: string, user: string, max: number, temp: number) {
  const r = await fetch('https://api.openai.com/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${process.env.OPENAI_API_KEY}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      model: 'gpt-4o-mini',
      messages: [ { role: 'system', content: system }, { role: 'user', content: user } ],
      max_tokens: max,
      temperature: temp
    })
  });
  const j = await r.json();
  return j.choices?.[0]?.message?.content ?? '…';
}

async function sendTelegramMessage(tokenEnc: string, chatId: number, text: string) {
  const token = tokenEnc; // TODO: расшифровать токен, здесь без шифрования для MVP
  await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ chat_id: chatId, text })
  });
}
```

