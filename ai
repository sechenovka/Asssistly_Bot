import 'dotenv/config';
import { Telegraf } from 'telegraf';
import { prisma } from '@danika/db/src/index.js';

const token = process.env.TELEGRAM_BOT_TOKEN!;
const bot = new Telegraf(token);

bot.start(async (ctx) => {
  await ctx.reply('Привет! Добавь меня в группу/канал и выдай права. Я зарегистрирую чат.');
});

bot.on('my_chat_member', async (ctx) => {
  const chat = ctx.myChatMember.chat;
  const type = chat.type;
  await prisma.bot.upsert({
    where: { username: process.env.TELEGRAM_BOT_USERNAME! },
    update: {},
    create: {
      owner: { connectOrCreate: { where: { tgId: BigInt(0) }, create: { tgId: BigInt(0) } } },
      tokenEnc: token,
      username: process.env.TELEGRAM_BOT_USERNAME!
    }
  });
  const botRow = await prisma.bot.findUnique({ where: { username: process.env.TELEGRAM_BOT_USERNAME! } });
  if (!botRow) return;
  await prisma.chat.upsert({
    where: { chatId: String(chat.id) },
    update: { title: (chat as any).title ?? chat.username ?? undefined, type, botId: botRow.id },
    create: { chatId: String(chat.id), title: (chat as any).title ?? chat.username ?? null, type, botId: botRow.id }
  });
});

bot.launch();
console.log('Bot worker started');
```

