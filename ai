'use client';
import { useEffect, useState } from 'react';

type Chat = { id: string; chatId: string; title?: string; type: string; settings?: any };

export default function Dashboard() {
  const [chats, setChats] = useState<Chat[]>([]);

  useEffect(() => {
    (async () => {
      const token = localStorage.getItem('token');
      const userId = token?.split('.')[1];
      const r = await fetch(process.env.NEXT_PUBLIC_API_URL + '/chats/' + userId);
      setChats(await r.json());
    })();
  }, []);

  const toggle = async (chatId: string, enabled: boolean) => {
    await fetch(process.env.NEXT_PUBLIC_API_URL + `/chats/${chatId}/settings`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ enabled }) });
    location.reload();
  };

  return (
    <main className="max-w-3xl mx-auto py-10">
      <h2 className="text-2xl font-semibold mb-4">Мои чаты</h2>
      <div className="space-y-3">
        {chats.map((c) => (
          <div key={c.id} className="bg-white border p-4 rounded-xl flex items-center justify-between">
            <div>
              <div className="font-medium">{c.title || c.chatId}</div>
              <div className="text-sm text-gray-500">{c.type}</div>
            </div>
            <div className="flex items-center gap-3">
              <a href={`/chat/${c.id}`} className="px-3 py-2 rounded-lg border">Изменить промпт</a>
              <button onClick={() => toggle(c.id, !(c.settings?.enabled))} className="px-3 py-2 rounded-lg bg-black text-white">
                {c.settings?.enabled ? 'Выключить' : 'Включить'}
              </button>
            </div>
          </div>
        ))}
      </div>
    </main>
  );
}
