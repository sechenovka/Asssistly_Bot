## apps/api/src/modules/auth.controller.ts
```ts
import { Controller, Post, Body, BadRequestException } from '@nestjs/common';
import { prisma } from '@danika/db/src/index.js';
import { validateTelegramAuth } from '@danika/shared/src/telegramLogin.js';

@Controller('auth')
export class AuthController {
  @Post('telegram')
  async telegramLogin(@Body() body: any) {
    const ok = validateTelegramAuth(body, process.env.TELEGRAM_LOGIN_BOT_TOKEN!);
    if (!ok) throw new BadRequestException('Invalid Telegram auth');

    const tgId = BigInt(body.id);
    const user = await prisma.user.upsert({
      where: { tgId },
      update: {
        tgUsername: body.username ?? null,
        firstName: body.first_name ?? null,
        lastName: body.last_name ?? null,
        photoUrl: body.photo_url ?? null,
      },
      create: {
        tgId,
        tgUsername: body.username ?? null,
        firstName: body.first_name ?? null,
        lastName: body.last_name ?? null,
        photoUrl: body.photo_url ?? null,
      },
    });
    return { token: `demo.${user.id}`, user: { id: user.id, username: user.tgUsername } };
  }
}
```

## apps/api/src/modules/chats.controller.ts
```ts
import { Controller, Get, Param, Post, Body, Put } from '@nestjs/common';
import { prisma } from '@danika/db/src/index.js';

@Controller('chats')
export class ChatsController {
  @Get(':userId')
  async list(@Param('userId') userId: string) {
    // Список чатов, которыми владеет user через его бота(ов)
    const bots = await prisma.bot.findMany({ where: { ownerId: userId }, include: { chats: { include: { settings: true } } } });
    return bots.flatMap(b => b.chats);
  }

  @Put(':chatId/settings')
  async updateSettings(@Param('chatId') chatId: string, @Body() dto: any) {
    const { enabled, prompt, temperature, maxTokens } = dto;
    const settings = await prisma.chatSettings.upsert({
      where: { chatId },
      update: { enabled, prompt, temperature, maxTokens },
      create: { chatId, enabled: !!enabled, prompt: prompt ?? '' }
    });
    return settings;
  }
}
